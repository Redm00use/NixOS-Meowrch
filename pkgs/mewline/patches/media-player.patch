diff --git a/src/mewline/widgets/dynamic_island/media.py b/src/mewline/widgets/dynamic_island/media.py
new file mode 100644
index 0000000..d3144b4
--- /dev/null
+++ b/src/mewline/widgets/dynamic_island/media.py
@@ -0,0 +1,84 @@
+import os
+from typing import TYPE_CHECKING
+from fabric.widgets.box import Box
+from fabric.widgets.label import Label
+from fabric.widgets.image import Image
+from fabric.widgets.button import Button
+from mewline.services.mpris import MprisPlayerManager, MprisPlayer
+from loguru import logger
+from mewline.widgets.dynamic_island.base import BaseDiWidget
+from mewline.utils.widget_utils import setup_cursor_hover
+from gi.repository import Gtk
+
+if TYPE_CHECKING:
+    from mewline.widgets.dynamic_island import DynamicIsland
+
+class Media(BaseDiWidget, Box):
+    focuse_kb: bool = False
+
+    def __init__(self, di: "DynamicIsland", **kwargs):
+        Box.__init__(
+            self,
+            name="media-menu",
+            orientation="h",
+            spacing=15,
+            v_align="center",
+            h_align="center",
+            v_expand=True,
+            h_expand=True,
+            visible=True,
+            **kwargs,
+        )
+        self.dynamic_island: "DynamicIsland" = di
+        self.mpris = MprisPlayerManager()
+        self.player: MprisPlayer | None = None
+
+        self.album_art = Image(name="media-album-art", width=48, height=48)
+        self.title_label = Label(name="media-title", label="Not Playing", ellipsize="end", h_align="start", width=150)
+        self.artist_label = Label(name="media-artist", label="Unknown Artist", ellipsize="end", h_align="start", width=150)
+        self.info_box = Box(orientation="v", spacing=0, v_align="center", children=[self.title_label, self.artist_label])
+
+        self.prev_button = Button(name="media-control-button", child=Label(label="󰒮", name="media-icon"), on_clicked=lambda *_: self._prev())
+        self.play_pause_button = Button(name="media-control-button", child=Label(label="󰐊", name="media-icon"), on_clicked=lambda *_: self._play_pause())
+        self.next_button = Button(name="media-control-button", child=Label(label="󰒭", name="media-icon"), on_clicked=lambda *_: self._next())
+        self.controls_box = Box(orientation="h", spacing=8, v_align="center", children=[self.prev_button, self.play_pause_button, self.next_button])
+
+        self.add(self.album_art)
+        self.add(self.info_box)
+        self.add(self.controls_box)
+
+        setup_cursor_hover(self.prev_button, "pointer")
+        setup_cursor_hover(self.play_pause_button, "pointer")
+        setup_cursor_hover(self.next_button, "pointer")
+
+        self.mpris.connect("player-appeared", self.on_player_appeared)
+        players = self.mpris.players
+        if players:
+            self.on_player_appeared(self.mpris, players[0])
+
+    def on_player_appeared(self, mpris, player):
+        self.player = MprisPlayer(player)
+        self.player.connect("changed", lambda *_: self.update_ui())
+        self.update_ui()
+
+    def update_ui(self):
+        if not self.player: return
+        self.title_label.set_label(self.player.title or "Unknown Title")
+        self.artist_label.set_label(self.player.artist or "Unknown Artist")
+        icon = "󰏤" if self.player.playback_status == "playing" else "󰐊"
+        self.play_pause_button.get_child().set_label(icon)
+        
+        art_url = self.player.arturl
+        if art_url:
+            path = art_url.replace("file://", "")
+            if os.path.exists(path): self.album_art.set_from_file(path)
+        else:
+            self.album_art.set_from_icon_name("audio-x-generic-symbolic", 48)
+
+    def _prev(self): 
+        if self.player: self.player.previous()
+    def _play_pause(self): 
+        if self.player: self.player.play_pause()
+    def _next(self): 
+        if self.player: self.player.next()
+    def open_widget_from_di(self): self.update_ui()
